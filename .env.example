PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Clerk — JWT verification (required in production; get from Clerk Dashboard → API Keys)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Clerk webhooks — Dashboard → Webhooks → endpoint signing secret (user.deleted cleanup)
CLERK_WEBHOOK_SIGNING_SECRET=

# Supabase — server-side only (Dashboard → Settings → API → service_role key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated origins for CORS (e.g. http://localhost:8081). Leave empty in dev to allow all.
CORS_ORIGINS=

# Rate limiting (optional — defaults shown)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_API_MAX_IP=120
# RATE_LIMIT_API_MAX_USER=100
# RATE_LIMIT_WRITE_MAX=60

# Supabase migrations — run in Supabase SQL Editor in this exact order:
# 001_initial_schema.sql → 002_domain_tables.sql → 003_storage_buckets.sql
# → 004_rls_policies.sql → 005_user_id_fk.sql → 006_rls_user_id.sql
# → 008_user_data_views.sql → 009_customer_id.sql
